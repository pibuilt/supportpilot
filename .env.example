ENV=dev

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=supportpilot

DATABASE_URL=postgresql://postgres:postgres@postgres:5432/supportpilot

OLLAMA_URL=http://host.docker.internal:11434
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
OLLAMA_LLM_MODEL=qwen2.5:1.5b

OPENAI_API_KEY=
OPENAI_BASE_URL=https://openrouter.ai/api/v1
OPENAI_MODEL=openrouter/free

# Additional discovered variables
OLLAMA_EMBED_DIMENSION=768
OLLAMA_EMBED_VERSION=v1
LLM_PROVIDER=ollama

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_TTL=86400

REDIS_URL=redis://redis:6379/0

JWT_SECRET_KEY=your_jwt_secret_key

LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your_langchain_api_key
LANGCHAIN_PROJECT=supportpilot-dev

# LangSmith tracing variables (do not use real secrets in example)
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=your_langsmith_api_key
LANGSMITH_PROJECT="supportpilot-dev"